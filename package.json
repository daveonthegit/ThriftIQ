{
  "name": "thriftiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-setup.ps1",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:start:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "dev:start:bash": "bash scripts/start-dev.sh",
    "dev:stop:bash": "bash scripts/stop-dev.sh",
    "dev:health": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-health.ps1",
    "db:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-setup.ps1",
    "db:setup:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-setup.ps1",
    "db:check:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-check.ps1",
    "db:setup:bash": "bash scripts/db-setup.sh",
    "db:check:bash": "bash scripts/db-check.sh",
    "storage:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/storage-setup.ps1",
    "storage:setup:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/storage-setup.ps1",
    "storage:setup:bash": "bash scripts/storage-setup.sh",
    "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "build": "next build",
    "build:local": "node scripts/build-local.mjs",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "user:grant-unlimited": "node scripts/set-search-entitlement.mjs grant",
    "user:revoke-unlimited": "node scripts/set-search-entitlement.mjs revoke"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.77",
    "@supabase/supabase-js": "^2.49.4",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/next-plugin": "^2.0.0-rc.41",
    "@tanstack/react-query": "^5.100.6",
    "@upstash/redis": "^1.35.5",
    "@vercel/analytics": "^1.5.0",
    "ai": "^6.0.168",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "postgres": "^3.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.54.2",
    "tamagui": "^2.0.0-rc.41",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "typescript": "^5.7.2"
  }
